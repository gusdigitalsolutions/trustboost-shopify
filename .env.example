# TrustBoost — Environment Variables
# Copy this file to .env and fill in your values

# ── Shopify App Credentials ───────────────────────────────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# Scopes needed (comma-separated, no spaces)
SCOPES=read_products,write_script_tags,read_orders,read_analytics

# ── Server ────────────────────────────────────────────────────────────────────
# Your public-facing URL (use ngrok in development, your domain in production)
HOST=https://your-ngrok-or-domain-url.com
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite database file (relative to project root)
DB_PATH=./data/trustboost.db

# ── Environment ───────────────────────────────────────────────────────────────
# 'development' | 'production'
NODE_ENV=development

# ── Client (Vite) ─────────────────────────────────────────────────────────────
# The Shopify API key is also needed by the React client
VITE_SHOPIFY_API_KEY=your_shopify_api_key_here
